# ============================================
# Nginx Monitor - Variables de entorno
# ============================================
# Copiar a .env y editar con valores reales:
#   cp .env.example .env

# --- Seguridad ---

# Clave secreta para sesiones Flask (generar una aleatoria)
SECRET_KEY=change-me-in-production

# Credenciales de acceso al dashboard (HTTP Basic Auth)
AUTH_USER=admin
AUTH_PASS=change-me-in-production

# Contraseña de PostgreSQL (usada por docker-compose)
POSTGRES_PASSWORD=change-me-in-production

# --- Sites y aplicaciones ---

# Dominios/sites a monitorizar (separados por comas)
# El primero es el site por defecto
MONITOR_SITES=example.com,example.org

# Aplicaciones web (formato: slug:Label, separadas por comas)
# El primero es la app por defecto para URIs no reconocidas
MONITOR_APPS=wordpress:WordPress,myapp:My App

# --- Puertos SSH/VPN ---

# Puertos SSH para categorizar bloqueos UFW (separados por comas)
MONITOR_SSH_PORTS=22,2222

# Puertos VPN/SSH para monitoreo de conexiones (formato: puerto:Nombre)
MONITOR_VPN_PORTS=22:SSH,1194:OpenVPN,51820:WireGuard
