# Systemd service to reload Nginx when ip_access.conf changes
# Triggered by nginx-ip-reload.path

[Unit]
Description=Reload Nginx after IP list config change
After=nginx.service

[Service]
Type=oneshot
ExecStartPre=/usr/sbin/nginx -t
ExecStart=/usr/sbin/nginx -s reload
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
